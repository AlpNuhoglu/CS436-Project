# ── Database ────────────────────────────────────────────────────────────────
# Senaryo A — Backend de Docker'da (docker compose up):
#   DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ders_forumu
# Senaryo B — Sadece DB Docker'da, backend lokal (docker compose up -d db):
#   DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ders_forumu
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ders_forumu

# ── Application ─────────────────────────────────────────────────────────────
DEBUG=false

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Güvenli bir secret üret: openssl rand -hex 32
JWT_SECRET=BURAYA_GUCLU_BIR_SECRET_YAZ_openssl_rand_hex_32
JWT_EXPIRE_MINUTES=10080

# ── E-posta / OTP ────────────────────────────────────────────────────────────
ALLOWED_EMAIL_DOMAIN=sabanciuniv.edu
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Gmail SMTP — boş bırakılırsa OTP konsola yazılır (geliştirme modu, mail gitmez).
# Gmail'de "Uygulama Şifresi" oluşturmak için: Google Hesabı → Güvenlik → 2FA açık → Uygulama şifreleri
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=GMAIL_ADRESIN@gmail.com
SMTP_PASSWORD=GMAIL_UYGULAMA_SIFRESI_16_KARAKTER
SMTP_FROM=GMAIL_ADRESIN@gmail.com
SMTP_USE_TLS=true
